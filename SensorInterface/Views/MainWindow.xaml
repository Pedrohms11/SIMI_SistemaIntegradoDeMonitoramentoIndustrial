<Window x:Class="SensorInterface.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SensorInterface"
        mc:Ignorable="d"
        Title="Interface de Sensores" 
        Height="450"
        Width="800">
    <StackPanel>
        <Button Content="Atualizar"
                Margin="6"
                Command="{Binding CarregarSensoresCommand}" />

        <Label Content="🌡️ Temperaturas" 
               FontSize="14" 
               FontWeight="Bold"
               Margin="0,10,0,5"/>

        <!-- ScrollViewer para Temperaturas -->
        <ScrollViewer Height="210" Margin="6">
            <ListBox ItemsSource="{Binding Temperaturas}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding StringFormat={}{0}°C}" />
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </ScrollViewer>

        <Label Content="📐 Ângulos" 
               FontSize="14" 
               FontWeight="Bold"
               Margin="0,10,0,5"/>

        <!-- ScrollViewer para Angulos -->
        <ScrollViewer Height="210" Margin="6">
            <ListBox ItemsSource="{Binding Angulos}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding StringFormat={}{0}°}" />
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </ScrollViewer>
    </StackPanel>
</Window>
